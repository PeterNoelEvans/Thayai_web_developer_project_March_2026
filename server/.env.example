# Thayai API - Environment Template
# Copy to .env and fill in your values

# Server port (3201 avoids conflict with LMS on 3000, 3101, and 3200)
PORT=3201

# PostgreSQL - SEPARATE database from LMS
# Create database: createdb thayai_db
DATABASE_URL=postgresql://username:password@localhost:5432/thayai_db

# Node environment
NODE_ENV=development
